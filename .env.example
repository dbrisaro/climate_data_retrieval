# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# AWS credentials (only needed if uploading to S3)
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_DEFAULT_REGION=us-east-1

# CDS API (ERA5 downloads)
# Full setup guide: https://cds.climate.copernicus.eu/api-how-to
# Alternatively configure via ~/.cdsapirc
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=your-uid:your-api-key-here
